#!/usr/bin/env python3
"""PDF Digest Generator - CLI entry point.

Usage:
    source venv/bin/activate
    python pdf-digest input.pdf -o output.md

Or run directly (no activate needed):
    ./pdf-digest input.pdf -o output.md
"""

import sys
from pathlib import Path


def main() -> None:
    project_root = Path(__file__).resolve().parent
    sys.path.insert(0, str(project_root / "src"))

    from pdf_digest.presentation.cli.app import app

    app()


if __name__ == "__main__":
    main()